{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Duckton Node",
  "version": "0.1.1",
  "identifier": "com.duckton.node",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Duckton Node",
        "width": 1180,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "backgroundColor": "#0a0a0b"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Run your machine as a Duckton P2P DuckDB grid node.",
    "longDescription": "Duckton Node turns your computer into a node on the Duckton peer-to-peer DuckDB compute grid. Donate a slice of RAM/CPU, serve verified queries over QUIC, and optionally earn — settled on The Open Network (TON), on testnet or mainnet. No central broker.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "copyright": "Copyright © Duckton — Apache-2.0",
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null,
      "entitlements": null
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.digicert.com"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {}
}
