# Rust / build
/target
**/target/
/dist

# MkDocs documentation site build output (rendered by `mkdocs build` / deployed
# to the gh-pages branch by CI — never commit the rendered HTML).
/site

# DuckDB Community-Extensions build flow (extension-ci-tools / `make release`)
/build
/configure
duckdb_unittest_tempdir
/test/bin

# Node / Acton / TON tooling
node_modules/
**/node_modules/
# TON build outputs are generated by the contract toolchain and not committed,
# EXCEPT the compiled JobEscrow code cell, which the `ton-live` settlement build
# embeds at compile time via include_str! (crates/settlement/src/wiring.rs). It
# must be present in a clean checkout (e.g. CI) for the desktop app to build.
ton/build/*
!ton/build/JobEscrow.json
*.boc
*.fif

# Secrets, wallets, deploy env — NEVER commit
*.env
.env*
global.wallets.toml
*.wallets.toml
*.mnemonic
*.secret
secrets.toml
*credentials*
*.key
*.pem
ton/deployments/
**/deployments/

# misc
.DS_Store
*.log
__pycache__/
*.pyc

# Generated artifacts — regenerated by docker/gen_compose.py; keep consistent
# in the tree but do not let stale copies accumulate across branches.
docker/compose.generated.yml

# runtime state
runtime.toml
blocklist.toml
