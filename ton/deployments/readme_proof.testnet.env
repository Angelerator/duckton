# Live on-chain money-flow proof (TON testnet) — captured for the README.
#
# A deliberately low-cost re-verification at 1/10 the prior amounts (base = 0.004
# TON instead of 0.04) so it fits a small deployer balance. The economic SPLIT is
# identical to the full-amount run: φ = 15% platform fee to the admin treasury,
# κ = 5% verifier commission, escrow covers all parties, free-winner refunds base.
# The FULL-amount proof (all 7 scenarios incl. the complete staking deposit->mint
# ->unbond lifecycle and every negative) is in upgrade_proof.testnet.env +
# docs/HOW_IT_WORKS.md.
#
# PUBLIC DATA ONLY — addresses, tx hashes, amounts. No seeds/mnemonics/keys.
# Captured Thu 18 Jun 2026 (UTC). Testnet only.
export TON_NETWORK="testnet"
export EXPLORER_BASE="https://testnet.tonviewer.com"

# --- Reused live contracts (verified live via read-only getters; not redeployed) ---
export GLOBAL_PARAMS_ADDR="kQC_cuafJQo9cycuivJfPHE5XGMrvZUP-1sN1Kq0jtZg3dna"   # admin=deployer, feeRecipient=treasury, platform_fee_bps=1500 (15%), participation_commission_bps=500 (5%), params_version=1
export STAKE_VAULT_ADDR="kQAYPc8qAo5YUKpgcTANIAi1umHrEhrp2nG_Lnkycvo0G29q"     # owner=deployer, min_stake=0, unbonding=7d
export STAKE_RECEIPT_WALLET="kQC2uYnSZcZW2EXJkUXE5QESw8DUwITtam5qt-E0q7ZoM4Wl" # deployer's Duckton receipt-jetton wallet (balance 0.1, transfer-locked)

# --- Parties (addresses only) ---
export DEPLOYER_REQUESTER_ARBITER="kQBfRkK8mJMD87yeozXp98PclFUPysbLiX6z7eJC1-JXAarQ"
export TREASURY_FEE_RECIPIENT="kQAl4XDL1zstQxysQeLPHJMlxSKvI_VcS2pBNzcPhqdZWXtT"  # == GlobalParams.fee_recipient
export VERIFIER="kQCkcSNzW6BHYivOVBiYTogG1zU1xsD51s9Svs0N-u_alr-g"               # wallet verifier (earns 5%)
export WINNER_WALLET="kQAw1XK6-Cdoh5W7BU8YpP0DNEa0wlYm-wlDTWZLOr-SX-1q"          # active wallet winner (frost-owl)
export FREE_WINNER="kQA6Azm9JTzvtpFF2ME6r9i6MrX_5ZXkSdgdMCehbsSsXm1e"           # walletless/free winner (tidal-fox, uninitialized)

# Amounts (nanoton): base=0.004 (4000000), fee=0.0006=15% (600000), commission=0.0002=5% (200000), B=0.005 (5000000).
# Each escrow permanently retains MIN_TONS_FOR_STORAGE = 0.05 TON as a storage
# reserve (funded from the deploy gas buffer, NOT from B). Each payout leg also
# pays a tiny per-message storage rent on landing (~0.00006 TON), so a recipient's
# balance delta is its gross leg minus that rent.

# === Scenario 1 — PAID, wallet winner (the headline 15%/5% split) =============
export S1_ESCROW="kQAu9lXxoz85k_Vybi0gc7L-qOaha2LbWl9pncoL5ZCNVaYz"
export S1_SETTLE_TX="esV7vGN2yx10DW6Vs7p5oBlstTsBAYNcNu2KZ5PIJyo="   # EscrowSettle 0.03 -> 4 EscrowPayout legs (settled=true)
# Gross payout legs (from trace): winner 0.004 | treasury 0.0006 | verifier 0.0002 | requester refund 0.029047929
# Balance deltas (gross leg minus per-leg storage rent):
export S1_WINNER_DELTA="+0.003941082"     # 0.706763103 -> 0.710704185  (base 0.004)
export S1_TREASURY_DELTA="+0.000541085"   # 0.091723175 -> 0.092264260  (15% fee 0.0006)
export S1_VERIFIER_DELTA="+0.000141085"   # 0.103671232 -> 0.103812317  (5% commission 0.0002)
export S1_DEPLOYER_DELTA="-0.058898844"   # 0.255890655 -> 0.196991811  (0.05 reserve + payouts + gas - refund)
export S1_ESCROW_RETAINED="0.05"          # storage reserve

# === Scenario 2 — PAID, free/walletless winner (base refunded, fee STILL 15%) =
export S2_ESCROW="kQA7gKDku9jO_ejMabspoXraox9a1U9zXLg3wnavlIo9KCBy"
export S2_SETTLE_TX="NW4y+JrjLju0CY88j+wcGHTclgORR72lTHFUbllbBOQ="   # EscrowSettle 0.03 -> 3 EscrowPayout legs (no winner leg; settled=true)
# Gross payout legs: treasury 0.0006 | verifier 0.0002 | requester refund 0.033198929 (incl. the unpaid base 0.004)
export S2_FREE_WINNER_DELTA="0"           # 0 -> 0  (free winner is paid nothing)
export S2_TREASURY_DELTA="+0.000548128"   # 0.092264260 -> 0.092812388  (15% still collected)
export S2_VERIFIER_DELTA="+0.000148128"   # 0.103812317 -> 0.103960445  (5%)
export S2_DEPLOYER_DELTA="-0.054737617"   # 0.196991811 -> 0.142254194  (cheaper than S1 by ~base, which refunds)
export S2_ESCROW_RETAINED="0.05"

