# Mainnet GlobalParams deploy parameters (real funds).
#
# Usage:
#   1) Create + FUND a mainnet deployer wallet (no airdrop on mainnet):
#        acton wallet new --name deployer --version v5r1
#      then send ~2-3 TON to the printed address.
#   2) Copy this file to `.env.mainnet`, set GP_FEE_RECIPIENT (treasury), and
#      source it (or pass inline) when running:
#        acton script scripts/deploy_global_params.tolk --net mainnet
#   3) Verify: acton verify GlobalParams
#
# Keep secrets (the deployer mnemonic) in Infisical — NEVER commit them. This
# example file holds only NON-secret parameters.

# Treasury / platform fee recipient (REQUIRED). Defaults to the deployer if unset,
# but you should set an explicit treasury (ideally a multisig).
GP_FEE_RECIPIENT=

# Economic params — defaults match BLOCKCHAIN_ECONOMICS §12 if left unset.
# φ platform fee = 15% (1500 bps); κ participation commission = 5% (500 bps).
GP_PLATFORM_FEE_BPS=1500
GP_PARTICIPATION_BPS=500
GP_SURCHARGE_BPS=500

# Stake floors (TON) by data class, and the per-node cap.
GP_MIN_STAKE=0
GP_MIN_STAKE_INTERNAL=100
GP_MIN_STAKE_SENSITIVE=1000
GP_STAKE_CAP=100000

# Timelocks (seconds): 7-day unbonding, 24h code-upgrade delay.
GP_UNBONDING_SECS=604800
GP_UPGRADE_DELAY_SECS=86400
